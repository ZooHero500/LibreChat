# YunYi (essjoy AI 平台) 环境变量模板
# 复制为 .env 并填入真实值；真实 .env 已被 .gitignore 忽略，切勿提交密钥。
# 这些是在上游 LibreChat .env 基础上，YunYi 部署需要额外/修改的项。

# ---- 对外地址(HTTPS 由 Caddy 提供) ----
HOST=0.0.0.0
PORT=3080
DOMAIN_CLIENT=https://chat.essjoy.com
DOMAIN_SERVER=https://chat.essjoy.com
NODE_ENV=production
UID=1000
GID=1000

# ---- 鉴权：关闭公开注册，账号由命令行创建 ----
ALLOW_EMAIL_LOGIN=true
ALLOW_REGISTRATION=false
ALLOW_SOCIAL_LOGIN=false

# ---- LibreChat 安全密钥(用 openssl 生成) ----
# CREDS_KEY=openssl rand -hex 32   (64位)
# CREDS_IV=openssl rand -hex 16    (32位)
# JWT_SECRET / JWT_REFRESH_SECRET=openssl rand -hex 32
# MEILI_MASTER_KEY=openssl rand -hex 16
CREDS_KEY=
CREDS_IV=
JWT_SECRET=
JWT_REFRESH_SECRET=
MEILI_MASTER_KEY=
MONGO_URI=mongodb://mongodb:27017/LibreChat

# ---- 模型供应商 Key(对应 librechat.yaml 的自定义端点) ----
# APImart 聚合(对话 claude-opus-4-8/gpt-5.5 + 生图 grok/gemini/gpt-image-2)
APIMART_KEY=
# 对话经 adapter 的内网地址(librechat.yaml 的 APImart baseURL 读这个)
# docker-compose: http://apimart-adapter:8000/v1 ; Railway: http://apimart-adapter.railway.internal:8000/v1
APIMART_BASE_URL=http://apimart-adapter:8000/v1

# ---- 内置生图工作台(LibreChat 内 /draw 页,替代独立的 apimart-studio) ----
# 默认经 apimart-adapter 出图(容器内 HTTP,避开 api 容器直连外网的 TLS 干扰),并复用 APIMART_KEY。
# 通常无需设置以下两项:
# IMAGE_GEN_API_BASE_URL=http://apimart-adapter:8000/v1
# IMAGE_GEN_API_KEY=     # 缺省回退到 APIMART_KEY
# DeepSeek 官方 (https://api.deepseek.com)
DEEPSEEK_API_KEY=
# OpenRouter (x-ai/grok-4.3)
OPENROUTER_API_KEY=

# ---- 联网搜索(Tavily 搜索+抓取 / Jina 重排,对应 librechat.yaml 的 webSearch) ----
TAVILY_API_KEY=
JINA_API_KEY=

# ---- 生图工作台/门户(apimart-studio) ----
# STUDIO_SECRET=openssl rand -hex 24   (门户/生图会话签名)
STUDIO_SECRET=
# 单点登录共享 Cookie 的父域
COOKIE_DOMAIN=.essjoy.com
